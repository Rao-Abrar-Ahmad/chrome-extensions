{
  "manifest_version": 3,
  "name": "Upwork Keyword Finder",
  "version": "1.0.0",
  "description": "Scrape, store, and analyze Upwork job listings. Find top keywords with AI.",
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png"
    },
    "default_title": "Open Upwork Keyword Finder"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/nx/search/jobs/*",
        "https://www.upwork.com/jobs/*",
        "https://www.upwork.com/freelance-jobs/*"
      ],
      "js": [
        "content/scraper.js",
        "content/highlighter.js",
        "content/content-main.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["content/toolbar.js"],
      "css": ["content/toolbar.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": ["https://www.upwork.com/*"]
}
