{
  "manifest_version": 3,
  "name": "Personal Assistant",
  "version": "1.0.0",
  "description": "Your daily productivity companion — notes, reminders, and daily tasks in Chrome's side panel.",

  "permissions": ["storage", "alarms", "notifications", "sidePanel", "contextMenus"],

  "action": {
    "default_title": "Open Personal Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
